{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/backtest",
      "dest": "/api/backtest.py"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.py"
    },
    {
      "src": "/api/optimize",
      "dest": "/api/optimize.py"
    },
    {
      "src": "/api/parse-strategy",
      "dest": "/api/parse_strategy.py"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
